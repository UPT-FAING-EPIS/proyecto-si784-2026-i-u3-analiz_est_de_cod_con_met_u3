{
  "name": "upt-code-analyzer",
  "displayName": "UPT Code Analyzer",
  "description": "Analizador Estático de Código con Métricas para UPT",
  "version": "0.0.2",
  "publisher": "anestatico",
  "repository": {
    "type": "git",
    "url": "https://github.com/UPT-FAING-EPIS/proyecto-si784-2026-i-u2-analiz_est_de_cod_con_met"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "uptAnalyzer.analyzeFile",
        "title": "UPT Analyzer: Analizar archivo actual"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "@types/form-data": "^2.5.0",
    "@typescript-eslint/eslint-plugin": "^6.4.1",
    "@typescript-eslint/parser": "^6.4.1",
    "eslint": "^8.47.0",
    "typescript": "^5.1.6",
    "ts-loader": "^9.4.4",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "form-data": "^4.0.0"
  }
}
